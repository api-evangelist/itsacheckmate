        {
          "id": "662113b5-f7f9-40df-8ee9-19393c0f5d0e",
          "name": "ItsaCheckmate Create or Refresh Token",
          "request": {
            "name": "ItsaCheckmate Create or Refresh Token",
            "description": {
              "content": "Issues an access token and refresh token using the authorization_code grant (initial issuance) or the refresh_token grant (renewal). Access tokens expire in 24 hours by default. Tokens are scoped; the menus scope is required to call the Get Menu endpoint.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "oauth",
                "token"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
