{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/itsacheckmate/refs/heads/main/json-structure/marketplace-api-menu-item-structure.json",
  "name": "MenuItem",
  "description": "A single menu item.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Item identifier."
    },
    "name": {
      "type": "string",
      "description": "Item name."
    },
    "description": {
      "type": "string",
      "description": "Item description."
    },
    "price": {
      "type": "int64",
      "description": "Item price in the smallest currency unit (cents)."
    },
    "available": {
      "type": "boolean",
      "description": "Whether the item is currently available."
    }
  }
}